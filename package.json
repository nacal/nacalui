{
  "name": "nacalui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:docs": "pnpm --filter @nacalui/docs storybook",
    "build:tokens": "pnpm --filter @nacalui/tokens build",
    "build:ui": "pnpm --filter @nacalui/ui build",
    "build:docs": "pnpm --filter @nacalui/docs build-storybook",
    "build": "pnpm build:tokens && pnpm build:ui",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "pnpm --filter @nacalui/ui test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@nacal-tools/biome-config": "^0.2.2",
    "wrangler": "^4.78.0"
  }
}
