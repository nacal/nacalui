{
  "name": "@nacalui/ui",
  "version": "0.1.0",
  "description": "UI component library for nacalui design system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nacal/nacalui",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nacalui.js"
    },
    "./style.css": "./dist/style.css",
    "./styles": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/components"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nacalui/tokens": "workspace:*",
    "clsx": "^2.1.1",
    "react-aria-components": "^1.16.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.99",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.8.0",
    "unocss": "^66.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
