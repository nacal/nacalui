{
  "name": "@nacalui/tokens",
  "version": "0.1.0",
  "description": "Design tokens for nacalui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nacal/nacalui",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./uno-preset": {
      "types": "./dist/uno-preset/index.d.ts",
      "import": "./dist/uno-preset/index.js"
    },
    "./css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node dist/src/generate-css.js",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "~6.0.2",
    "unocss": "^66.0.0"
  }
}
